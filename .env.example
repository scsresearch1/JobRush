# Firebase Web Config (get from Firebase Console → Project Settings → General → Your apps)
# Add these to .env.local for local development

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=jobrush-f2eb4.firebaseapp.com
# projectId / authDomain / databaseURL: jobrush_client/src/config/firebaseJobbrushDefaults.js (Netlify PROJECT_ID/AUTH_DOMAIN ignored by SDK)
VITE_FIREBASE_PROJECT_ID=jobrush-f2eb4
VITE_FIREBASE_STORAGE_BUCKET=jobrush-f2eb4.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# AI API (for explanations & recommendations)
# Add your API key to .env or set when running server
GROQ_API_KEY=your-api-key

# API server URL (for production - point to your deployed backend)
# Leave empty for local dev (Vite proxy forwards /api to localhost:3001)
# VITE_API_URL=http://localhost:3001

# Optional: override bundled payment QR (initial asset: jobrush_client/public/payment-phonepe-qr.png → /payment-phonepe-qr.png)
# VITE_PAYMENT_QR_URL=https://your-cdn.example.com/jobrush-upi-qr.png

# --- API server (server/index.js) — payment notification & outbound mail ---
# When a user submits a payment reference, the API emails PAYMENT_NOTIFY_TO (default: hirefortune90@gmail.com).
# Use a Gmail App Password or your SMTP provider:
# PAYMENT_NOTIFY_TO=hirefortune90@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=hirefortune90@gmail.com
# SMTP_PASS=your-google-app-password
# MAIL_FROM=hirefortune90@gmail.com
