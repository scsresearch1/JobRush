# Copy to .env.local — same Firebase web config as main JobRush app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=jobrush-f2eb4.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://jobrush-f2eb4-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=jobrush-f2eb4
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: JobRush API base for dashboard "Service health" (default: https://jobrush.onrender.com)
# VITE_JOBRUSH_API_BASE=

# Required for payment approval/rejection emails from User management (must match ADMIN_API_SECRET on the API server)
# VITE_ADMIN_API_SECRET=

