# Copy to .env.local — same Firebase web config as main JobRush app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=jobrush-f2eb4.firebaseapp.com
# Firebase project + RTDB: src/config/firebaseJobbrushDefaults.js
VITE_FIREBASE_PROJECT_ID=jobrush-f2eb4
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: JobRush API base for dashboard "Service health" (default: https://jobrush.onrender.com)
# VITE_JOBRUSH_API_BASE=

# Required for admin-triggered email actions (payment approval/rejection and report sharing)
VITE_ADMIN_API_SECRET=

# Admin username/password live in Firebase: adminPortal/credentials
# Seed defaults (sd.niladri@gmail.com / JBRush@2026) with: npm run firebase:create-collections
