{
  "name": "jobrush",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "JobRush.ai monorepo — client, admin, API",
  "workspaces": [
    "jobrush_client",
    "jobrush_admin",
    "TestingEngine"
  ],
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "dompurify": "^3.2.4",
    "node-fetch": "^2.7.0",
    "esbuild": "^0.25.0"
  },
  "scripts": {
    "dev": "npm run dev -w jobrush_client",
    "build": "npm run build -w jobrush_client && npm run build -w jobrush_admin && node scripts/copy-jadm-to-dist.js",
    "preview": "npm run preview -w jobrush_client",
    "server": "node server/index.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev -w jobrush_client\"",
    "admin:dev": "npm run dev -w jobrush_admin",
    "admin:build": "npm run build -w jobrush_admin",
    "firebase:create-collections": "node scripts/create-firebase-collections.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
