GROQ_API_KEY=

# Optional Groq models (defaults save tokens on free tier: 8B for most routes, 70B only for full-resume JSON edits)
# GROQ_MODEL=llama-3.1-8b-instant
# GROQ_MODEL_HEAVY=llama-3.3-70b-versatile

# Groq SDK call timeout (ms), clamped 15s–300s. Default 120000.
# GROQ_SDK_TIMEOUT_MS=120000

# Listen address (default 0.0.0.0 for Render/Docker)
# BIND_HOST=0.0.0.0

# On Render (RENDER=true): periodic GET /api/health to reduce cold sleeps. Set ENABLE_SELF_PING=0 to disable.
# SELF_PING_INTERVAL_MS=720000

# Resend (required for email workflows)
RESEND_API_KEY=

# Inbox for new-user / payment-request admin alerts (default hirefortune90@gmail.com)
# ADMIN_NOTIFY_EMAIL=hirefortune90@gmail.com

# Shared secret used by admin-origin email endpoints
ADMIN_API_SECRET=

# Optional: override Realtime Database URL if server code reads Firebase again later.
# FIREBASE_DATABASE_URL=
