GROQ_API_KEY=

# Shared secret: admin portal sends Authorization: Bearer <this> to /api/admin/notify-payment-decision
# Must match VITE_ADMIN_API_SECRET in the JobRush admin (Netlify) build.
ADMIN_API_SECRET=

# Outbound email (payment decisions, “email latest reports” from admin). Example: Gmail app password, SendGrid SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Optional: same Realtime Database URL as the app (…firebasedatabase.app). When set, the API loads SMTP + From from
# adminPortal/emailOutbound if you configure it in JobRush admin → Settings (env vars above still override per field).
# FIREBASE_DATABASE_URL=
