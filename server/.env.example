GROQ_API_KEY=

# Shared secret: admin portal sends Authorization: Bearer <this> to /api/admin/notify-payment-decision
# Must match VITE_ADMIN_API_SECRET in the JobRush admin (Netlify) build.
ADMIN_API_SECRET=

# Outbound email (payment decisions, “email latest reports” from admin). Example: Gmail app password, SendGrid SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Fast outbound email (HTTPS to Resend — no SMTP from Render). https://resend.com
# RESEND_API_KEY=
# RESEND_FROM=JobRush <onboarding@resend.dev>
# RESEND_TIMEOUT_MS=12000

# Optional: Render→Gmail often needs IPv4 (default). Set SMTP_FORCE_IPV4=0 to use system default.
# SMTP_FORCE_IPV4=
# Optional: SMTP connect/socket timeout ms (default 15000).
# SMTP_CONNECT_TIMEOUT_MS=

# Optional: override Realtime Database URL (default is baked into server/index.js as DEFAULT_FIREBASE_RTDB_URL).
# FIREBASE_DATABASE_URL=
